{
  "name": "deepseek-code-cli",
  "version": "1.0.0",
  "description": "在终端中使用 DeepSeek-V4 模型进行 AI 辅助编程（Vibe Coding），缓存命中率 99.6%，极致降低 API 成本。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zlf1238/deepseek-code-cli.git"
  },
  "bin": {
    "deepseek-code": "./dist/cli.cjs"
  },
  "main": "./dist/cli.cjs",
  "files": [
    "dist/cli.cjs",
    "docs/tools/**",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "esbuild ./src/cli.tsx --bundle --platform=node --format=cjs --target=node18 --outfile=dist/cli.cjs --banner:js=\"#!/usr/bin/env node\" --packages=external",
    "build": "npm run typecheck && npm run bundle && node -e \"process.platform!=='win32'&&require('fs').chmodSync('dist/cli.cjs','755')\"",
    "test": "tsx --test src/tests/*.test.ts",
    "test:single": "tsx --test",
    "prepack": "npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "get-east-asian-width": "^1.6.0",
    "gray-matter": "^4.0.3",
    "ignore": "^5.3.2",
    "marked": "^18.0.4",
    "openai": "^5.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "esbuild": "^0.25.12",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
